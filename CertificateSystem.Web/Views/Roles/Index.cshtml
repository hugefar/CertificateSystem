@model CertificateSystem.Web.Models.RoleListViewModel
@{
    ViewData["Title"] = "角色管理";
}

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span>&times;</span></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span>&times;</span></button>
            </div>
        }

        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">角色筛选</h3>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index" class="form-inline">
                    <input type="text" class="form-control mr-2" name="keyword" value="@Model.Keyword" placeholder="角色名称" />
                    <button type="submit" class="btn btn-primary mr-2"><i class="fas fa-search"></i> 搜索</button>
                    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus"></i> 新增角色</a>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">角色列表</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th>角色名称</th>
                            <th>用户数量</th>
                            <th>权限数量</th>
                            <th>数据范围</th>
                            <th style="width:300px;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Roles.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-muted">暂无数据</td></tr>
                        }
                        else
                        {
                            @foreach (var role in Model.Roles)
                            {
                                <tr>
                                    <td>@role.Name</td>
                                    <td>@role.UserCount</td>
                                    <td>@role.PermissionCount</td>
                                    <td>@(string.IsNullOrWhiteSpace(role.DataScope) ? "Institute" : role.DataScope)</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-info"><i class="fas fa-edit"></i> 编辑</a>
                                        <a asp-action="AssignPermissions" asp-route-id="@role.Id" class="btn btn-sm btn-primary"><i class="fas fa-key"></i> 权限分配</a>
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('确认删除该角色吗？');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@role.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> 删除</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
