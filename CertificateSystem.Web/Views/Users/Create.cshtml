@model CertificateSystem.Web.Models.CreateUserViewModel
@{
    ViewData["Title"] = "新增用户";
}

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">新增用户</h3>
            </div>
            <form asp-action="Create" method="post" id="createForm">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="JobNum"></label>
                            <input asp-for="JobNum" class="form-control" />
                            <span asp-validation-for="JobNum" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="FullName"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Department"></label>
                            <input asp-for="Department" class="form-control" />
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Password"></label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="ConfirmPassword"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>角色分配</label>
                        <div class="row">
                            @for (var i = 0; i < Model.AvailableRoles.Count; i++)
                            {
                                <div class="col-md-3">
                                    <div class="icheck-primary d-inline">
                                        <input type="checkbox" name="RoleIds" value="@Model.AvailableRoles[i].Value" id="role_@i" @(Model.RoleIds.Contains(long.Parse(Model.AvailableRoles[i].Value!)) ? "checked" : null) />
                                        <label for="role_@i">@Model.AvailableRoles[i].Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <a asp-action="Index" class="btn btn-secondary">取消</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
