@model CertificateSystem.Web.Models.EditUserViewModel
@{
    ViewData["Title"] = "编辑用户";
}

<section class="content">
    <div class="container-fluid">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h3 class="card-title">编辑用户</h3>
            </div>
            <form asp-action="Edit" method="post" id="editForm">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div class="card-body">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="JobNum"></label>
                            <input asp-for="JobNum" class="form-control" readonly />
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="FullName"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Department"></label>
                            <input asp-for="Department" class="form-control" />
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="IsActive"></label>
                            <div class="mt-2">
                                <div class="custom-control custom-switch">
                                    <input asp-for="IsActive" class="custom-control-input" id="isActiveSwitch" />
                                    <label class="custom-control-label" for="isActiveSwitch">启用该账户</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>角色分配</label>
                        <div class="row">
                            @for (var i = 0; i < Model.AvailableRoles.Count; i++)
                            {
                                var roleId = long.Parse(Model.AvailableRoles[i].Value!);
                                <div class="col-md-3">
                                    <div class="icheck-primary d-inline">
                                        <input type="checkbox" name="RoleIds" value="@Model.AvailableRoles[i].Value" id="role_@i" @(Model.RoleIds.Contains(roleId) ? "checked" : null) />
                                        <label for="role_@i">@Model.AvailableRoles[i].Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <a asp-action="Index" class="btn btn-secondary">取消</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
