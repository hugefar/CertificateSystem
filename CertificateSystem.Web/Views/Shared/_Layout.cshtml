@using CertificateSystem.Web.Identity
@using CertificateSystem.Web.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@inject UserManager<ApplicationUser> UserManager
@inject IAuthorizationService AuthorizationService

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CertificateSystem</title>
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/dist/css/adminlte.css" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="/" class="nav-link">首页</a>
                </li>
            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                @if (User?.Identity != null && User.Identity.IsAuthenticated)
                {
                    var displayName = User.Identity.Name;
                    var currentUser = await UserManager.GetUserAsync(User);
                    if (currentUser != null && !string.IsNullOrWhiteSpace(currentUser.FullName))
                    {
                        displayName = currentUser.FullName;
                    }
                    var fullName = currentUser?.FullName ?? "-";
                    var jobNum = currentUser?.JobNum ?? "-";
                    var department = currentUser?.Department ?? "-";

                    <li class="nav-item dropdown user-menu">
                        <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
                            <img src="~/dist/img/user2-160x160.jpg" class="user-image img-circle elevation-2" alt="User Image">
                            <span class="d-none d-md-inline">@displayName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                            <li class="user-header bg-primary">
                                <img src="~/dist/img/user2-160x160.jpg" class="img-circle elevation-2" alt="User Image">
                                <p>
                                    @displayName
                                    <small>职工号：@jobNum</small>
                                    <small>部门：@department</small>
                                </p>
                            </li>
                            @* <li class="user-body">
                                <div class="row">
                                    <div class="col-12 text-center">
                                        <a href="/Account/Profile" class="btn btn-default btn-flat">个人资料</a>
                                    </div>
                                </div>
                            </li> *@
                            <li class="user-footer">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-default btn-block">退出</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    if (!string.Equals(currentController, "Account", System.StringComparison.OrdinalIgnoreCase)
                        || !string.Equals(currentAction, "Login", System.StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">登录</a>
                        </li>
                    }
                }
            </ul>
        </nav>
        <!-- /.navbar -->

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-light-primary elevation-4">
            <!-- Brand Logo -->
            <a href="/" class="brand-link">
                <img src="~/dist/img/logo.png" alt="Logo" class="brand-image img-circle elevation-3" style="opacity:.8">
                <span class="brand-text font-weight-light">证书打印系统</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- (user panel moved to navbar) -->

                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        @{
                            var canViewDashboard = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Dashboard.View"))).Succeeded;
                            var canManageGraduation = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Certificate.Graduation"))).Succeeded;
                            var canManageCompletion = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Certificate.Completion"))).Succeeded;
                            var canManageDegree = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Certificate.Degree"))).Succeeded;
                            var canManageSecondDegree = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Certificate.SecondDegree"))).Succeeded;
                            var canViewUsers = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("User.View"))).Succeeded;
                            var canViewRoles = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("Role.View"))).Succeeded;
                            var canViewSecurityLog = (await AuthorizationService.AuthorizeAsync(User, null, new PermissionRequirement("SecurityLog.View"))).Succeeded;
                        }

                        @if (canViewDashboard)
                        {
                            <li class="nav-item">
                                <a href="/" class="nav-link">
                                    <i class="nav-icon fas fa-home"></i>
                                    <p>首页</p>
                                </a>
                            </li>
                        }
                        @if (canManageGraduation)
                        {
                            <li class="nav-item">
                                <a href="/Certificate/Graduation" class="nav-link">
                                    <i class="nav-icon fas fa-certificate"></i>
                                    <p>毕业证书</p>
                                </a>
                            </li>
                        }
                        @if (canManageCompletion)
                        {
                            <li class="nav-item">
                                <a href="/Certificate/Completion" class="nav-link">
                                    <i class="nav-icon fas fa-award"></i>
                                    <p>结业证书</p>
                                </a>
                            </li>
                        }
                        @if (canManageDegree)
                        {
                            <li class="nav-item">
                                <a href="/Certificate/Degree" class="nav-link">
                                    <i class="nav-icon fas fa-graduation-cap"></i>
                                    <p>学位证书</p>
                                </a>
                            </li>
                        }
                        @if (canManageSecondDegree)
                        {
                            <li class="nav-item">
                                <a href="/Certificate/SecondDegree" class="nav-link">
                                    <i class="nav-icon fas fa-user-graduate"></i>
                                    <p>第二学位证书</p>
                                </a>
                            </li>
                        }
                        @if (canViewUsers)
                        {
                            <li class="nav-item">
                                <a href="/Users" class="nav-link">
                                    <i class="nav-icon fas fa-users"></i>
                                    <p>用户管理</p>
                                </a>
                            </li>
                        }
                        @if (canViewRoles)
                        {
                            <li class="nav-item">
                                <a href="/Roles" class="nav-link">
                                    <i class="nav-icon fas fa-user-tag"></i>
                                    <p>角色管理</p>
                                </a>
                            </li>
                        }
                        @if (canViewSecurityLog && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a href="/SecurityLog" class="nav-link">
                                    <i class="nav-icon fas fa-shield-alt"></i>
                                    <p>安全日志</p>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1>@ViewData["Title"]</h1>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="#">Home</a></li>
                                <li class="breadcrumb-item active">@ViewData["Title"]</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Main content -->
            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <footer class="main-footer">
            <div class="float-right d-none d-sm-inline">Certificate System</div>
            <strong>&copy; 2026 <a href="#">Your Company</a>.</strong> All rights reserved.
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.js"></script>
    <script>
        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
